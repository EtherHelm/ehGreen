subroutine kernel_piz_batch(r, z, n, res) bind(C, name="kernel_piz_batch")
use iso_c_binding
implicit none
integer(c_int), intent(in), value :: n
real(c_double), intent(in) :: r(n), z(n)
real(c_double), intent(out) :: res(4, n)

real(8) :: tmp(4)
integer :: i

!$OMP PARALLEL DO PRIVATE(tmp)
do i = 1, n
      call kernel_piz(r(i), z(i), tmp)
      res(1, i) = tmp(1)
      res(2, i) = tmp(2)
      res(3, i) = tmp(3)
      res(4, i) = tmp(4)
end do
!$OMP END PARALLEL DO
end subroutine
subroutine kernel_piz(r,z,res) bind(C, name="kernel_piz")
  implicit none
  !GCC$ ATTRIBUTES DLLEXPORT:: kernel_piz
  !DEC$ ATTRIBUTES DLLEXPORT:: kernel_piz
  real(8),intent(in)    ::  r,z
  real(8),intent(out)  ::  res(4)
  real(8):: expZ,j0,j1
  expZ = quickExp(z)*PI2

  
  call besselJ(r,j0,j1)
  res(2) = expZ*J0
  res(4) = -expZ*J1
  if(r<0.36d0 .and. z<0.36d0)then
    call greenExpr(r,z,res)
  elseif(r<40d0 .and. z<16d0)then
    call greenTble(r,z,res)
  elseif(r<40d0)then
    call greenTble2(r,1d0/z,res)
  else
    res(1) = -0.5*expZ*Y0H0fuse(r)
    res(3) = 0.5*expZ*Y1H1fuse(r)
    if(z<16d0)then
      call greenTble3(1d0/r,dsqrt(z),res)
    else
      call greenTble4(1d0/r,1d0/z,res)
    endif
  endif

endsubroutine
